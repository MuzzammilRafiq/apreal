{
	"name": "@apreal/relay-server",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "node --watch --conditions=development --import tsx src/index.ts",
		"start": "node dist/src/index.js",
		"build": "rm -rf dist && pnpm --dir ../shared build && tsc -p tsconfig.json && node scripts/prepare-dist.mjs",
		"typecheck": "tsc --noEmit -p tsconfig.json",
		"test": "node --conditions=development --import tsx --test src/tests/*.test.ts",
		"test:dist": "node --test dist/src/tests/*.test.js"
	},
	"devDependencies": {
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node": "^25.6.0",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"@apreal/shared": "workspace:*",
		"@t3-oss/env-core": "^0.13.11",
		"better-auth": "^1.6.14",
		"dotenv": "^17.4.2",
		"jsonwebtoken": "^9.0.2",
		"kysely": "0.28.17",
		"zod": "^4.4.3"
	}
}