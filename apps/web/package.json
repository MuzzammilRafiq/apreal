{
	"name": "@apreal/web",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "pnpm dev:local",
		"dev:local": "vite --host --mode web-local",
		"dev:remote": "vite --host --mode remote",
		"prebuild": "pnpm --dir ../shared build",
		"prebuild:local": "pnpm --dir ../shared build",
		"prebuild:remote": "pnpm --dir ../shared build",
		"build": "pnpm build:local",
		"build:local": "vite build --mode web-local",
		"build:remote": "vite build --mode remote",
		"preview": "pnpm preview:local",
		"preview:local": "vite preview --mode web-local",
		"preview:remote": "vite preview --mode remote",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@apreal/shared": "workspace:*",
		"better-auth": "^1.6.14",
		"highlight.js": "^11.11.1",
		"lucide-react": "^1.18.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"react-markdown": "^10.1.0",
		"react-scan": "^0.5.3",
		"rehype-highlight": "^7.0.2",
		"remark-gfm": "^4.0.1"
	},
	"devDependencies": {
		"@tailwindcss/vite": "^4.2.2",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@vitejs/plugin-react": "^6.0.0",
		"tailwindcss": "^4.2.2",
		"typescript": "^5.9.3",
		"vite": "^8.0.0"
	}
}
