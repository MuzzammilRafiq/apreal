{
	"name": "@apreal/web",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "pnpm dev:local",
		"dev:local": "vite --host --mode web-local",
		"dev:remote": "vite --host --mode remote",
		"prebuild": "pnpm --dir ../shared build",
		"prebuild:local": "pnpm --dir ../shared build",
		"prebuild:remote": "pnpm --dir ../shared build",
		"build:version": "node ./scripts/write-build-version.mjs",
		"build": "pnpm build:local",
		"build:local": "pnpm build:version && vite build --mode web-local",
		"build:remote": "pnpm build:version && vite build --mode remote",
		"preview": "pnpm preview:local",
		"preview:local": "vite preview --mode web-local",
		"preview:remote": "vite preview --mode remote",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@apreal/shared": "workspace:*",
		"ai": "^6.0.204",
		"better-auth": "^1.6.14",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"lucide-react": "^1.18.0",
		"nanoid": "^5.1.11",
		"radix-ui": "^1.5.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"react-markdown": "^10.1.0",
		"react-scan": "^0.5.3",
		"rehype-raw": "^7.0.0",
		"rehype-sanitize": "^6.0.0",
		"remark-breaks": "^4.0.0",
		"remark-gfm": "^4.0.1",
		"shadcn": "^4.11.0",
		"shiki": "^4.2.0",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.6.0",
		"tw-animate-css": "^1.4.0",
		"use-stick-to-bottom": "^1.1.6"
	},
	"devDependencies": {
		"@tailwindcss/vite": "^4.3.1",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@vitejs/plugin-react": "^6.0.0",
		"tailwindcss": "^4.3.1",
		"typescript": "^5.9.3",
		"vite": "^8.0.0",
		"vite-plugin-pwa": "^1.3.0"
	}
}
