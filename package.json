{
  "name": "desktop",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "workspaces": [
    "apps/*"
  ],
  "engines": {
    "node": ">=20.6.0"
  },
  "scripts": {
    "dev": "turbo run dev --ui=tui --parallel --filter=@apreal/server --filter=@apreal/web",
    "dev:plain": "turbo run dev --parallel --filter=@apreal/server --filter=@apreal/web",
    "dev:logs": "node --import tsx scripts/dev-runner.ts",
    "dev:mobile": "pnpm --dir apps/mobile dev",
    "dev:server": "pnpm --dir apps/server dev",
    "dev:web": "pnpm --dir apps/web dev",
    "dev:web:local": "pnpm --dir apps/web dev:local",
    "dev:web:remote": "pnpm --dir apps/web dev:remote",
    "android:mobile": "pnpm --dir apps/mobile android",
    "ios:mobile": "pnpm --dir apps/mobile ios",
    "web:mobile": "pnpm --dir apps/mobile web",
    "lint:mobile": "pnpm --dir apps/mobile lint",
    "build:server": "pnpm --dir apps/server build",
    "build:web": "pnpm --dir apps/web build",
    "build:web:local": "pnpm --dir apps/web build:local",
    "build:web:remote": "pnpm --dir apps/web build:remote",
    "build:relay": "pnpm --dir apps/relay-server build",
    "build:shared": "pnpm --dir apps/shared build",
    "start:server": "pnpm --dir apps/server start",
    "start:mobile": "pnpm --dir apps/mobile start",
    "typecheck:mobile": "pnpm --dir apps/mobile typecheck",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "clean": "rm -rf node_modules apps/*/node_modules apps/*/dist .turbo"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsx": "^4.22.3",
    "turbo": "^2.9.16",
    "typescript": "^5.9.3"
  }
}
