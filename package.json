{
  "name": "desktop",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo run dev --ui=tui --parallel --filter=@apreal/server --filter=@apreal/web",
    "dev:plain": "turbo run dev --parallel --filter=@apreal/server --filter=@apreal/web",
    "dev:logs": "bun run scripts/dev-runner.ts",
    "dev:server": "bun run --cwd apps/server dev",
    "dev:web": "bun run --cwd apps/web dev",
    "start:server": "bun run --cwd apps/server start",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "clean": "rm -rf node_modules apps/*/node_modules apps/*/dist .turbo"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "@types/node": "^25.6.0",
    "turbo": "^2.5.0",
    "typescript": "^5.9.3"
  }
}
